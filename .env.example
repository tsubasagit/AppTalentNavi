# co-vibe: Multi-Provider AI Coding Agent
# Copy this file to .env and fill in your API keys
#
# セットアップウィザード: python3 setup.py
# Setup wizard:           python3 setup.py

# === Provider API Keys ===
# 少なくとも1つのキーが必要です / At least one key is required

# Gemini (gemini-2.0-flash — 無料枠あり / free tier available)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (Claude Opus 4.6, Sonnet 4.6, Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-4o-mini, o3)
OPENAI_API_KEY=sk-...

# Groq (Llama 3.3 70B - 超高速推論 / ultra-fast inference)
GROQ_API_KEY=gsk_...

# === Routing Strategy ===
# auto   - タスク複雑さで3段自動オーケストレーション (default)
#           simple → fast, normal → balanced, complex → strong
# strong - 常に最強モデル (Opus > o3)
# fast   - 最速レスポンス (Haiku > mini > Groq)
# cheap  - コスト最小化 (Haiku > mini > Groq)
CO_VIBE_STRATEGY=auto

# === 3-Tier Orchestration (optional overrides) ===
# デフォルトはAPIキーに応じて自動選択
# CO_VIBE_MODEL_STRONG=claude-opus-4-6      # 高難度: 設計/大規模リファクタ/難しいバグ
# CO_VIBE_MODEL_BALANCED=claude-sonnet-4-6   # 通常: コーディング/説明/中程度のタスク
# CO_VIBE_MODEL_FAST=claude-haiku-4-5-20251001  # 簡単: 質問/フォーマット/タイポ修正

# === Default Model (overrides orchestration) ===
# CO_VIBE_MODEL=claude-opus-4-6

# === Advanced ===
# CO_VIBE_DEBUG=1
